# ---- Supabase (required) ----
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key is ONLY used in trusted server contexts (e.g. admin
# bookings page). Never expose it to the browser. Leave it blank in
# preview deployments where you do not need admin reads.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
# Used to build absolute URLs (OAuth callbacks, SEO metadata, sitemaps).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: comma-separated list of emails granted admin access in the UI.
# These users will see the /admin dashboard. You can also flip the
# `is_admin` column on the `profiles` table.
ADMIN_EMAILS=admin@example.com
